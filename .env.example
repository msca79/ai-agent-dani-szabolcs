# LLM
ANTHROPIC_API_KEY=

# Postgres (docker-compose)
POSTGRES_DB=boardgame
POSTGRES_USER=boardgame
POSTGRES_PASSWORD=boardgame
# Host port a docker-compose Postgres-hez; 5433 az alapértelmezett, mert az 5432-t
# más helyi projekt is használhatja.
POSTGRES_PORT=5433

# Prisma — read-write kapcsolat (séma, migráció, seed)
DATABASE_URL=postgresql://boardgame:boardgame@localhost:5433/boardgame

# Agent belső tool-jai — read-only kapcsolat (csak SELECT, boardgame_ro role)
DATABASE_URL_READONLY=postgresql://boardgame_ro:boardgame_ro_dev_only@localhost:5433/boardgame
