# LLM
ANTHROPIC_API_KEY=

# Postgres (docker-compose)
POSTGRES_DB=boardgame
POSTGRES_USER=boardgame
POSTGRES_PASSWORD=boardgame

# Prisma — read-write kapcsolat (séma, migráció, seed)
DATABASE_URL=postgresql://boardgame:boardgame@localhost:5432/boardgame

# Agent belső tool-jai — read-only kapcsolat (csak SELECT, boardgame_ro role)
DATABASE_URL_READONLY=postgresql://boardgame_ro:boardgame_ro_dev_only@localhost:5432/boardgame
