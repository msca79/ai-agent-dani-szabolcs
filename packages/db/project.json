{
  "name": "db",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/db/src",
  "projectType": "library",
  "tags": ["type:data"],
  "// targets": "to see all targets run: nx show project db --web",
  "targets": {
    "validate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prisma validate",
        "cwd": "packages/db"
      }
    },
    "migrate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prisma migrate dev --name init_games",
        "cwd": "packages/db"
      }
    },
    "seed": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prisma db seed",
        "cwd": "packages/db"
      }
    },
    "generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prisma generate",
        "cwd": "packages/db"
      }
    }
  }
}
